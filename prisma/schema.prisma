  updatedAt   DateTime  @updatedAt
  Product     Product[]
  businesses  Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, name])
  @@index([businessId])
}

model categories {
  id               String       @id
  businessId       String
  name             String
  parentId         String?
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  Product          Product[]
  businesses       Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  categories       categories?  @relation("categoriesTocategories", fields: [parentId], references: [id])
  other_categories categories[] @relation("categoriesTocategories")

  @@unique([businessId, name])
  @@index([businessId])
  @@index([parentId])
}

model goods_receive_note_items {
  id                  String              @id
  grnId               String
  productId           String
  quantityOrdered     Float
  quantityReceived    Float
  quantityDamaged     Float               @default(0)
  price               Float               @default(0)
  batchNumber         String?
  serialNumbers       String[]
  goods_receive_notes goods_receive_notes @relation(fields: [grnId], references: [id], onDelete: Cascade)
  Product             Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model goods_receive_notes {
  id                       String                     @id
  businessId               String
  grnNumber                String
  purchaseOrderId          String?
  vendorId                 String
  warehouseId              String
  receivedDate             DateTime                   @default(now())
  status                   GrnStatus                  @default(RECEIVED)
  notes                    String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime
  Bill                     Bill[]
  goods_receive_note_items goods_receive_note_items[]
  businesses               Business                   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  PurchaseOrder            PurchaseOrder?             @relation(fields: [purchaseOrderId], references: [id])
  Vendor                   Vendor                     @relation(fields: [vendorId], references: [id])
  Warehouse                Warehouse                  @relation(fields: [warehouseId], references: [id])
  purchase_returns         purchase_returns[]

  @@unique([businessId, grnNumber])
  @@index([businessId])
}

model notifications {
  id         String    @id
  businessId String
  userId     String?
  title      String
  message    String
  type       String    @default("INFO")
  isRead     Boolean   @default(false)
  readAt     DateTime?
  entityType String?
  entityId   String?
  createdAt  DateTime  @default(now())
  businesses Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([userId])
}

model purchase_request_items {
  id                String            @id @default(uuid())
  purchaseRequestId String
  productId         String
  description       String?
  quantity          Float
  estimatedPrice    Float?            @default(0)
  itemType          String?
  hsnSacCode        String?
  Product           Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchase_requests purchase_requests @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
}

model purchase_requests {
  id                     String                   @id
  businessId             String
  requestNumber          String
  department             String?
  requesterId            String?
  status                 PurchaseRequestStatus    @default(DRAFT)
  notes                  String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  purchase_request_items purchase_request_items[]
  businesses             Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  business_users         BusinessUser?            @relation(fields: [requesterId], references: [id])

  @@unique([businessId, requestNumber])
  @@index([businessId])
}

model purchase_return_items {
  id               String           @id
  purchaseReturnId String
  productId        String
  description      String?
  quantity         Float
  price            Float
  taxPercent       Float?           @default(0)
  total            Float
  warehouseId      String?
  isStockReturned  Boolean          @default(false)
  Product          Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  purchase_returns purchase_returns @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  Warehouse        Warehouse?       @relation(fields: [warehouseId], references: [id])
}

model purchase_returns {
  id                    String                  @id
  businessId            String
  returnNumber          String
  vendorId              String
  billId                String?
  grnId                 String?
  status                PurchaseReturnStatus    @default(PENDING)
  reason                String?
  refundStatus          String                  @default("PENDING")
  subtotal              Float                   @default(0)
  tax                   Float                   @default(0)
  totalAmount           Float                   @default(0)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  purchase_return_items purchase_return_items[]
  Bill                  Bill?                   @relation(fields: [billId], references: [id])
  businesses            Business                @relation(fields: [businessId], references: [id], onDelete: Cascade)
  goods_receive_notes   goods_receive_notes?    @relation(fields: [grnId], references: [id])
  Vendor                Vendor                  @relation(fields: [vendorId], references: [id])

  @@unique([businessId, returnNumber])
  @@index([businessId])
}

model recurring_invoice_items {
  id                 String             @id
  recurringInvoiceId String
  productId          String?
  description        String
  itemType           String?            @default("GOODS")
  quantity           Float
  price              Float
  taxPercent         Float?             @default(0)
  taxDetails         Json?
  total              Float
  createdAt          DateTime           @default(now())
  updatedAt          DateTime
  Product            Product?           @relation(fields: [productId], references: [id])
  recurring_invoices recurring_invoices @relation(fields: [recurringInvoiceId], references: [id], onDelete: Cascade)
}

model recurring_invoices {
  id                      String                    @id
  businessId              String
  customerId              String
  profileName             String
  status                  String                    @default("ACTIVE")
  frequency               BillingFrequency          @default(MONTHLY)
  startDate               DateTime
  endDate                 DateTime?
  lastInvoiceDate         DateTime?
  nextInvoiceDate         DateTime?
  currency                String                    @default("INR")
  subtotal                Float                     @default(0)
  totalTax                Float                     @default(0)
  discount                Float                     @default(0)
  grandTotal              Float                     @default(0)
  notes                   String?
  terms                   String?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime
  recurring_invoice_items recurring_invoice_items[]
  businesses              Business                  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customers               Customer                  @relation(fields: [customerId], references: [id])

  @@index([businessId])
  @@index([customerId])
}

model sales_return_items {
  id              String        @id
  salesReturnId   String
  productId       String?
  description     String
  quantity        Float
  price           Float
  taxPercent      Float?        @default(0)
  total           Float
  warehouseId     String?
  isStockReturned Boolean       @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  Product         Product?      @relation(fields: [productId], references: [id])
  sales_returns   sales_returns @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)
  Warehouse       Warehouse?    @relation(fields: [warehouseId], references: [id])
}

model sales_returns {
  id                 String               @id
  businessId         String
  customerId         String
  invoiceId          String?
  salesOrderId       String?
  returnNumber       String               @unique
  status             SalesReturnStatus    @default(PENDING)
  reason             String?
  refundStatus       String               @default("PENDING")
  subtotal           Float                @default(0)
  tax                Float                @default(0)
  totalAmount        Float                @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  CreditNote         CreditNote[]
  sales_return_items sales_return_items[]
  businesses         Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customers          Customer             @relation(fields: [customerId], references: [id])
  invoices           Invoice?             @relation(fields: [invoiceId], references: [id])
  SalesOrder         SalesOrder?          @relation(fields: [salesOrderId], references: [id])

  @@index([businessId])
  @@index([customerId])
  @@index([invoiceId])
}

model serial_numbers {
  id           String             @id
  businessId   String
  productId    String
  batchId      String?
  serialNumber String
  status       SerialNumberStatus @default(IN_STOCK)
  warehouseId  String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime
  batches      batches?           @relation(fields: [batchId], references: [id])
  businesses   Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Product      Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  Warehouse    Warehouse?         @relation(fields: [warehouseId], references: [id])

  @@unique([businessId, productId, serialNumber])
  @@index([businessId])
  @@index([productId])
  @@index([serialNumber])
}

model stock_adjustment_items {
  id                String             @id
  stockAdjustmentId String
  productId         String
  quantity          Float
  type              AdjustmentItemType
  batchNumber       String?
  serialNumbers     String[]
  Product           Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  stock_adjustments stock_adjustments  @relation(fields: [stockAdjustmentId], references: [id], onDelete: Cascade)
}

model stock_adjustments {
  id                     String                   @id
  businessId             String
  adjustmentNumber       String
  warehouseId            String
  reason                 String?
  adjustmentDate         DateTime                 @default(now())
  notes                  String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  stock_adjustment_items stock_adjustment_items[]
  businesses             Business                 @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Warehouse              Warehouse                @relation(fields: [warehouseId], references: [id])

  @@unique([businessId, adjustmentNumber])
  @@index([businessId])
}

model stock_transfer_items {
  id              String          @id
  stockTransferId String
  productId       String
  quantity        Float
  batchNumber     String?
  serialNumbers   String[]
  Product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  stock_transfers stock_transfers @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
}

model stock_transfers {
  id                                                   String                 @id
  businessId                                           String
  transferNumber                                       String
  fromWarehouseId                                      String
  toWarehouseId                                        String
  status                                               StockTransferStatus    @default(PENDING)
  transferDate                                         DateTime               @default(now())
  notes                                                String?
  createdAt                                            DateTime               @default(now())
  updatedAt                                            DateTime               @updatedAt
  stock_transfer_items                                 stock_transfer_items[]
  businesses                                           Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Warehouse_stock_transfers_fromWarehouseIdToWarehouse Warehouse              @relation("stock_transfers_fromWarehouseIdToWarehouse", fields: [fromWarehouseId], references: [id])
  Warehouse_stock_transfers_toWarehouseIdToWarehouse   Warehouse              @relation("stock_transfers_toWarehouseIdToWarehouse", fields: [toWarehouseId], references: [id])

  @@unique([businessId, transferNumber])
  @@index([businessId])
}

model units {
  id          String    @id
  businessId  String
  name        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  Product     Product[]
  businesses  Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, name])
  @@index([businessId])
}

