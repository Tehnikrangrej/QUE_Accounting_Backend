generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(uuid())
  name             String
  email            String         @unique
  password         String
  createdAt        DateTime       @default(now())
  isActive         Boolean        @default(true)
  role             UserRole       @default(USER)
  updatedAt        DateTime       @updatedAt
  activeBusinessId String?
  employees        Employee?
  memberships      BusinessUser[]
  businessesOwned  Business[]     @relation("BusinessOwner")
  activeBusiness   Business?      @relation("ActiveBusiness", fields: [activeBusinessId], references: [id])
  settings         Settings[]     @relation("SettingsToUser")

  @@map("users")
}

model Business {
  id                  String                @id @default(uuid())
  name                String
  ownerId             String
  isActive            Boolean               @default(true)
  createdAt           DateTime              @default(now())
  accounts            Account[]
  activities          Activity[]
  bills               Bill[]
  Campaign            Campaign[]
  contracts           Contract[]
  contractTypes       ContractType[]
  creditNotes         CreditNote[]
  CrmTask             CrmTask[]
  customerContacts    CustomerContact[]
  deals               Deal[]
  EmailLog            EmailLog[]
  employees           Employee[]
  expenses            Expense[]
  journalEntries      JournalEntry[]
  leads               Lead[]
  LeadConversionLog   LeadConversionLog[]
  Note                Note[]
  overtimes           Overtime[]
  products            Product[]
  projects            Project[]
  PurchaseOrder       PurchaseOrder[]
  quotations          Quotation[]
  salesOrders         SalesOrder[]
  settings            Settings?
  timeEntries         TimeEntry[]
  vendors             Vendor[]
  warehouses          Warehouse[]
  audit_logs          audit_logs[]
  batches             batches[]
  brands              brands[]
  users               BusinessUser[]
  owner               User                  @relation("BusinessOwner", fields: [ownerId], references: [id])
  categories          categories[]
  customers           Customer[]
  goods_receive_notes goods_receive_notes[]
  invoices            Invoice[]
  notifications       notifications[]
  payments            Payment[]
  purchase_requests   purchase_requests[]
  purchase_returns    purchase_returns[]
  recurring_invoices  recurring_invoices[]
  roles               Role[]
  sales_returns       sales_returns[]
  serial_numbers      serial_numbers[]
  stock_adjustments   stock_adjustments[]
  stockMovements      StockMovement[]
  stock_transfers     stock_transfers[]
  subscription        Subscription?
  units               units[]
  activeUsers         User[]                @relation("ActiveBusiness")

    @@map("businesses")
    settings Settings[]
    payments Payment[]
    creditNotes CreditNote[]
    employees Employee[]
    overtimes Overtime[]
    expenses Expense[]
    customerContacts CustomerContact[]
    contracts Contract[]
    contractTypes ContractType[]
    leads Lead[]
    deals Deal[]
    activities Activity[]
    quotations Quotation[]
    salesOrders SalesOrder[]
    bills Bill[]
    purchaseOrders PurchaseOrder[]
    vendors Vendor[]
    warehouses Warehouse[]
    products Product[]
    journalEntries JournalEntry[]
    accounts Account[]
    
    timeEntries TimeEntry[]
    projects Project[]
}

  //////////////////////////////////////////////////////
  // BUSINESS USERS (User ↔ Business)
  //////////////////////////////////////////////////////

model BusinessUser {
  id                                           String              @id @default(uuid())
  userId                                       String
  businessId                                   String
  roleId                                       String
  isActive                                     Boolean             @default(true)
  createdAt                                    DateTime            @default(now())
  activities                                   Activity[]
  CrmTask_CrmTask_assignedToIdTobusiness_users CrmTask[]           @relation("CrmTask_assignedToIdTobusiness_users")
  CrmTask_CrmTask_createdByIdTobusiness_users  CrmTask[]           @relation("CrmTask_createdByIdTobusiness_users")
  CustomerContact                              CustomerContact[]
  deals                                        Deal[]
  leads                                        Lead[]
  LeadConversionLog                            LeadConversionLog[]
  Note                                         Note[]
  projectMembers                               ProjectMember[]
  PurchaseOrder                                PurchaseOrder[]
  quotations                                   Quotation[]
  salesOrders                                  SalesOrder[]
  taskAssignees                                TaskAssignee[]
  timeEntries                                  TimeEntry[]
  business                                     Business            @relation(fields: [businessId], references: [id])
  role                                         Role                @relation(fields: [roleId], references: [id])
  user                                         User                @relation(fields: [userId], references: [id])
  customers                                    Customer[]
  purchase_requests                            purchase_requests[]
  userPermissions                              UserPermission[]

    @@unique([userId, businessId]) // prevents duplicate membership
    @@index([businessId])
    @@map("business_users")
      deals Deal[]
    leads Lead[]
    activities Activity[]
    quotations Quotation[]
    salesOrders SalesOrder[]
    purchaseOrders PurchaseOrder[]
    projectMembers ProjectMember[]
    taskAssignees TaskAssignee[]
    timeEntries TimeEntry[]
}

  //////////////////////////////////////////////////////
  // ROLES (Business Scoped)
  //////////////////////////////////////////////////////

model Role {
  id              String           @id @default(uuid())
  name            String
  businessId      String
  createdAt       DateTime         @default(now())
  users           BusinessUser[]
  rolePermissions RolePermission[]
  business        Business         @relation(fields: [businessId], references: [id])

  @@unique([businessId, name])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  action          String
  moduleId        String
  module          Module           @relation(fields: [moduleId], references: [id])
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@unique([moduleId, action])
  @@map("permissions")
}

model Module {
  id          String       @id @default(uuid())
  name        String       @unique
  permissions Permission[]

  @@map("modules")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id             String       @id @default(uuid())
  businessUserId String
  permissionId   String
  businessUser   BusinessUser @relation(fields: [businessUserId], references: [id])
  permission     Permission   @relation(fields: [permissionId], references: [id])

  @@unique([businessUserId, permissionId])
  @@map("user_permissions")
}

/// ///////////////////////////////////////////////////
/// ///////////////////////////////////////////////////
model Customer {
  id              String   @id @default(uuid())

  //////////////////////////////////////////////////////
  // BUSINESS RELATION (REPLACE TENANT)
  //////////////////////////////////////////////////////
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  //////////////////////////////////////////////////////
  // CUSTOMER DETAILS
  //////////////////////////////////////////////////////
  company         String
  vatNumber       String?
  phone           String?
  website         String?
  group           String?
  currency        String   @default("SYSTEM")
  defaultLanguage String   @default("SYSTEM")

  //////////////////////////////////////////////////////
  // MAIN ADDRESS
  //////////////////////////////////////////////////////
  address         String?
  city            String?
  state           String?
  zipCode         String?
  country         String?

  //////////////////////////////////////////////////////
  // BILLING ADDRESS
  //////////////////////////////////////////////////////
  billingStreet   String?
  billingCity     String?
  billingState    String?
  billingZipCode  String?
  billingCountry  String?

  //////////////////////////////////////////////////////
  // SHIPPING ADDRESS
  //////////////////////////////////////////////////////
  shippingStreet  String?
  shippingCity    String?
  shippingState   String?
  shippingZipCode String?
  shippingCountry String?
    region     Region   // 🔥 ADD THIS

  //////////////////////////////////////////////////////
  // STATUS + META
  //////////////////////////////////////////////////////
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////
  invoices        Invoice[]
  leadId   String? @unique
  leads           Lead[]

  @@index([businessId])
  @@map("customers")
  creditNotes CreditNote[]
  customerContacts CustomerContact[]
  contracts Contract[]
  deals Deal[]
  activities Activity[]
  quotations Quotation[]
  salesOrders SalesOrder[]
  projects Project[]
}
enum Region {
  INDIA
  UAE
}

  //////////////////////////////////////////////////////
  // INVOICES
  //////////////////////////////////////////////////////

  model Invoice {
    id            String        @id @default(uuid())
    businessId    String
    customerId    String
    invoiceNumber String
    status        InvoiceStatus @default(UNPAID)
    invoiceDate   DateTime      @default(now())
    dueDate       DateTime?
    currency      String        @default("AED")
    poNumber      String?
    poDate        DateTime?
    soNumber      String?
    soDate        DateTime?

    //NOTE//
    adminNote String?
    terms    String?

    //totalAmount//
    subtotal Float @default(0)
    totalTax Float @default(0) 
    discount Float @default(0)
    grandTotal Float @default(0)
    
     //Business//
    createdAt     DateTime      @default(now())
    updatedAt     DateTime      @updatedAt

    pdfUrl                String?
    business Business @relation(fields: [businessId], references: [id])
    customer Customer @relation(fields: [customerId], references: [id])
    
    salesOrderId String?
    designTemplate String @default("modern")
salesOrder   SalesOrder? @relation(fields: [salesOrderId], references: [id])
    items    InvoiceItem[]

    projectId String?
project   Project? @relation(fields: [projectId], references: [id])

    @@unique([businessId, invoiceNumber]) // invoice numbers unique per business
    @@index([businessId])
    @@map("invoices")
      payments Payment[]
    creditNotes CreditNote[]
}
  enum CreatorType {
    Admin
    USER
  }

  //////////////////////////////////////////////////////
  // INVOICE ITEMS
  //////////////////////////////////////////////////////

  model InvoiceItem {
    id          String  @id @default(uuid())
    invoiceId   String
    description String
    hsnSacCode  String?
    itemType    String?
    hours Float
    rate Float
    taxDetails  Json?
     // 🔥 ADD THESE (IMPORTANT)
  totalTax    Float   @default(0)
  totalAmount Float   @default(0)
    amount  Float 
    createdAt   DateTime @default(now())
    invoice Invoice @relation(fields: [invoiceId], references: [id])

    @@map("invoice_items")
  }
enum InvoiceStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}
  //////////////////////////////////////////////////////
  // SUBSCRIPTIONS (Manual Billing Ready)
  //////////////////////////////////////////////////////

model Subscription {
  id         String             @id @default(uuid())
  businessId String             @unique
  status     SubscriptionStatus @default(INACTIVE)
  startDate  DateTime?
  expiresAt  DateTime?
  planName   String?
  notes      String?
  createdAt  DateTime           @default(now())
  business   Business           @relation(fields: [businessId], references: [id])

  @@map("subscriptions")
}

/// ///////////////////////////////////////////////////
/// ///////////////////////////////////////////////////
model Settings {
  id                Int      @id @default(autoincrement())
  businessId        String   @unique
  companyName       String
  address           String?
  phone             String?
  email             String?
  website           String?
  trn               String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  accountName       String?
  accountNumber     String?
  bankAddress       String?
  bankName          String?
  companyLogo       String?
  iban              String?
  swiftCode         String?
  defaultFooterNote String?
  defaultTerms      String?
  invoiceFormat     String   @default("INV-YYYY-MM-DD-COUNT")
  signatureUrl      String?
  leaveTypes        Json?
  overtimeThreshold Float    @default(2)
  currency          String   @default("INR")
  currencySymbol    String   @default("₹")
  invoiceTemplate   String   @default("modern")
  busniess          Business @relation(fields: [businessId], references: [id])
  users             User[]   @relation("SettingsToUser")
}

model Payment {
  id            String      @id @default(uuid())
  invoiceId     String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  businessId    String
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  amount        Float
  paymentDate   DateTime
  paymentMode   String
  transactionId String?
  note          String?
  createdAt     DateTime    @default(now())
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  createdBy     String
  pdfUrl        String?
  creditNoteId  String?
  paymentNumber String
  billId        String?
  bill          Bill?       @relation(fields: [billId], references: [id])
  business      Business    @relation(fields: [businessId], references: [id])
  creditNote    CreditNote? @relation(fields: [creditNoteId], references: [id])
  invoice       Invoice?    @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("payments")
}

model CreditNote {
  id               String   @id @default(uuid())

  ////////////////////////////////////////////////////
  // RELATIONS
  ////////////////////////////////////////////////////
  businessId       String
  customerId       String?
  invoiceId        String?   // nullable (credit may exist without invoice)
  vendorId         String?   // for bill credits
  business Business @relation(fields: [businessId], references: [id])
 customer Customer? @relation(fields: [customerId], references: [id])
  invoice  Invoice? @relation(fields: [invoiceId], references: [id])
  vendor   Vendor? @relation(fields: [vendorId], references: [id])

  ////////////////////////////////////////////////////
  // CREDIT DATA
  ////////////////////////////////////////////////////
  creditNumber     String
  type             CreditNoteType   // 🔥 ADD THIS
  amount           Float
  remainingAmount  Float

  reason           String?
  status           CreditNoteStatus @default(OPEN)
  pdfUrl           String?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([businessId])
  @@index([customerId])
}

model Employee {
  id                 String              @id @default(uuid())
  businessId         String
  name               String
  email              String?
  phone              String?
  designation        String?
  joinDate           DateTime?
  basicSalary        Float
  createdAt          DateTime            @default(now())
  allowance          Json?
  deduction          Json?
  leaveBalance       Json?
  userId             String?             @unique
  accountHolderName  String?
  accountNumber      String?
  bankName           String?
  Code               String?
  bankChangeRequests BankChangeRequest[]
  business           Business            @relation(fields: [businessId], references: [id])
  user               User?               @relation(fields: [userId], references: [id])
  leaves             Leave[]
  loans              Loan[]
  overtimes          Overtime[]
  payslips           Payslip[]
  projectMembers     ProjectMember[]
  taskAssignees      TaskAssignee[]
  timeEntries        TimeEntry[]
}

model Payslip {
  id            String   @id @default(uuid())
  payrollId     String
  employeeId    String
  basicSalary   Float
  allowance     Float    @default(0)
  deduction     Float    @default(0)
  netSalary     Float
  status        String   @default("pending")
  pdfUrl        String?
  createdAt     DateTime @default(now())
  employeeName  String
  overtimePay   Float    @default(0)
  loanDeduction Float    @default(0)
  employee      Employee @relation(fields: [employeeId], references: [id])
  payroll       Payroll  @relation(fields: [payrollId], references: [id])
}

model Payroll {
  id         String    @id @default(uuid())
  businessId String
  month      Int
  year       Int
  status     String    @default("draft")
  createdAt  DateTime  @default(now())
  payslips   Payslip[]
}

model Leave {
  id         String   @id @default(uuid())
  businessId String
  employeeId String
  leaveCode  String
  date       DateTime
  duration   String
  createdAt  DateTime @default(now())
  status     String   @default("PENDING")
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model BankChangeRequest {
  id                String        @id @default(uuid())
  employeeId        String
  businessId        String
  bankName          String
  accountNumber     String
  accountHolderName String
  status            RequestStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  Code              String
  country           String
  employee          Employee      @relation(fields: [employeeId], references: [id])
}

model Overtime {
  id            String   @id @default(uuid())
  employeeId    String
  businessId    String
  overtimeHours Float
  date          DateTime
  createdAt     DateTime @default(now())
  business      Business @relation(fields: [businessId], references: [id])
  employee      Employee @relation(fields: [employeeId], references: [id])

  @@index([businessId, employeeId])
}

model Loan {
  id              String   @id @default(uuid())
  employeeId      String
  businessId      String
  totalAmount     Float
  remainingAmount Float
  emiAmount       Float
  startDate       DateTime
  status          String   @default("active")
  createdAt       DateTime @default(now())
  employee        Employee @relation(fields: [employeeId], references: [id])
}

model Expense {
  id            String   @id @default(uuid())
  businessId    String
  title         String
  amount        Float
  category      String
  paymentMethod String
  date          DateTime
  notes         String?
  vendorId      String?
  createdAt     DateTime @default(now())
  business      Business @relation(fields: [businessId], references: [id])
  vendor        Vendor?  @relation(fields: [vendorId], references: [id])
}

model Vendor {
  id         String   @id @default(uuid())

  //////////////////////////////////////////////////////
  // BUSINESS
  //////////////////////////////////////////////////////
  businessId String
  business   Business @relation(fields: [businessId], references: [id])

  //////////////////////////////////////////////////////
  // BASIC INFO
  //////////////////////////////////////////////////////
  name       String
  email      String?
  phone      String?

  //////////////////////////////////////////////////////
  // COMPANY DETAILS
  //////////////////////////////////////////////////////
  vatNumber  String?
  website    String?

  //////////////////////////////////////////////////////
  // ADDRESS
  //////////////////////////////////////////////////////
  address    String?
  city       String?
  state      String?
  zipCode    String?
  country    String?

  //////////////////////////////////////////////////////
  // STATUS
  //////////////////////////////////////////////////////
  isActive   Boolean  @default(true)

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////
  expenses        Expense[]
  purchaseOrders  PurchaseOrder[]   // ✅ NEW
  bills           Bill[]            // ✅ FUTURE

  //////////////////////////////////////////////////////
  // META
  //////////////////////////////////////////////////////
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  creditNotes CreditNote[]
}

model CustomerContact {
  id          String   @id @default(uuid())

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////
  customerId  String
  businessId  String

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  //////////////////////////////////////////////////////
  // FIELDS (FROM YOUR UI)
  //////////////////////////////////////////////////////
  fullName    String
  email       String?
  position    String?
  phone       String?

  isActive    Boolean  @default(true)

  //////////////////////////////////////////////////////
  // META
  //////////////////////////////////////////////////////
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([customerId])
  @@index([businessId])
  deals Deal[]
}

model Contract {
  id          String         @id @default(uuid())
  businessId  String
  customerId  String
  title       String
  description String?
  value       Float
  currency    String
  startDate   DateTime
  endDate     DateTime?
  isDeleted   Boolean        @default(false)
  isHidden    Boolean        @default(false)
  status      ContractStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime  @updatedAt       
  typeId      String?
  business    Business       @relation(fields: [businessId], references: [id])
  customer    Customer       @relation(fields: [customerId], references: [id])
  type        ContractType?  @relation(fields: [typeId], references: [id])

  @@index([businessId])
  @@index([customerId])
}

model ContractType {
  id         String     @id @default(uuid())
  name       String
  businessId String
  createdAt  DateTime   @default(now())
  contracts  Contract[]
  business   Business   @relation(fields: [businessId], references: [id])

  @@unique([businessId, name])
}

model Lead {
  id              String   @id @default(uuid())
  businessId      String
  business        Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name            String
  position        String?
  email           String?
  phone           String?

  company         String?
  website         String?

  city            String?
  state           String?
  country         String?
  zipCode         String?

  status          LeadStatus   @default(NEW)
  source          LeadSource

   assignedToId String?
assignedTo   BusinessUser? @relation(fields: [assignedToId], references: [id])
  tags            String[]
  leadValue       Float?

  description     String?
  isPublic        Boolean  @default(false)
  contactedToday  Boolean  @default(false)
  defaultLanguage String?

  stageId         String?
  stage           PipelineStage? @relation(fields: [stageId], references: [id])

  activities      LeadActivity[]
  notes           LeadNote[]
  tasks           LeadTask[]
  reminders       LeadReminder[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  customers Customer[]

  activity Activity[]
}

model PipelineStage {
  id    String  @id @default(uuid())
  name  String
  order Int
  color String?
  leads Lead[]
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String
  message   String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id])
}

model LeadNote {
  id        String   @id @default(uuid())
  leadId    String
  note      String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id])
}

model LeadTask {
  id        String   @id @default(uuid())
  leadId    String
  title     String
  status    String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id])
}

model LeadReminder {
  id     String   @id @default(uuid())
  leadId String
  title  String
  date   DateTime
  lead   Lead     @relation(fields: [leadId], references: [id])
}

model Deal {
  id                String             @id @default(uuid())
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  businessId        String
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  name              String
  amount            Float
  currency          String             @default("INR")
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  customerId        String
  contactId         String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  stage             String             @default("New")
  probability       Int?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  expectedCloseDate DateTime?

  //////////////////////////////////////////////////////
  // META
  //////////////////////////////////////////////////////
  assignedToId String?
assignedTo   BusinessUser? @relation(fields: [assignedToId], references: [id])
  source     String?
  description String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([businessId])
  @@index([customerId])
  activities Activity[]
  quotations Quotation[]
  salesOrders SalesOrder[]
}

model Activity {
  id          String   @id @default(uuid())

  //////////////////////////////////////////////////////
  // BUSINESS
  //////////////////////////////////////////////////////
  businessId  String
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  //////////////////////////////////////////////////////
  // BASIC INFO
  //////////////////////////////////////////////////////
  type        String   // Call, Meeting
  title       String
  description String?

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////
  leadId      String?
  lead        Lead? @relation(fields: [leadId], references: [id])

  dealId      String?
  deal        Deal? @relation(fields: [dealId], references: [id])

  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])

  //////////////////////////////////////////////////////
  // ASSIGNED USER (BusinessUser)
  //////////////////////////////////////////////////////
  assignedToId String?
  assignedTo   BusinessUser? @relation(fields: [assignedToId], references: [id])

  //////////////////////////////////////////////////////
  // DATE
  //////////////////////////////////////////////////////
  activityDate DateTime
  duration     Int?

  //////////////////////////////////////////////////////
  // STATUS
  //////////////////////////////////////////////////////
  status       String   @default("Scheduled")

  //////////////////////////////////////////////////////
  // META
  //////////////////////////////////////////////////////
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([businessId])
}

model Quotation {
  id            String   @id @default(uuid())

  //////////////////////////////////////////////////////
  // BUSINESS
  //////////////////////////////////////////////////////
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  //////////////////////////////////////////////////////
  // BASIC INFO
  //////////////////////////////////////////////////////
  quoteNumber   String   @unique
  title         String?

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])

  dealId        String?
  deal          Deal? @relation(fields: [dealId], references: [id])

  assignedToId  String?
  assignedTo    BusinessUser? @relation(fields: [assignedToId], references: [id])

  //////////////////////////////////////////////////////
  // STATUS
  //////////////////////////////////////////////////////
  status        String   @default("Draft")

  //////////////////////////////////////////////////////
  // PRICING
  //////////////////////////////////////////////////////
  subtotal      Float
  tax           Float?
  discount      Float?
  totalAmount   Float

  //////////////////////////////////////////////////////
  // DATES
  //////////////////////////////////////////////////////
  issueDate     DateTime
  expiryDate    DateTime?

  //////////////////////////////////////////////////////
  // NOTES
  //////////////////////////////////////////////////////
  notes         String?

  //////////////////////////////////////////////////////
  // RELATION
  //////////////////////////////////////////////////////
  items         QuotationItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId])
  salesOrders SalesOrder[]
}

model QuotationItem {
  id           String   @id @default(uuid())

  quotationId  String
  quotation    Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  description  String
  itemType     String?  @default("GOODS")
  hsnSacCode   String?
  quantity     Float
  price        Float
  taxPercent   Float?   @default(0)
  total        Float
}

model SalesOrder {
  id            String   @id @default(uuid())

  //////////////////////////////////////////////////////
  // BUSINESS
  //////////////////////////////////////////////////////
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  //////////////////////////////////////////////////////
  // BASIC
  //////////////////////////////////////////////////////
  orderNumber   String   @unique
  status        String   @default("Draft")

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////
  customerId    String
  customer      Customer @relation(fields: [customerId], references: [id])

  quotationId   String?
  quotation     Quotation? @relation(fields: [quotationId], references: [id])

  dealId        String?
  deal          Deal? @relation(fields: [dealId], references: [id])

  assignedToId  String?
  assignedTo    BusinessUser? @relation(fields: [assignedToId], references: [id])

  //////////////////////////////////////////////////////
  // PRICING
  //////////////////////////////////////////////////////
  subtotal      Float
  tax           Float?
  discount      Float?
  totalAmount   Float

  //////////////////////////////////////////////////////
  // DATES
  //////////////////////////////////////////////////////
  orderDate     DateTime
  deliveryDate  DateTime?

  //////////////////////////////////////////////////////
  // NOTES
  //////////////////////////////////////////////////////
  notes         String?

  items         SalesOrderItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId])
  invoices Invoice[]
}

model SalesOrderItem {
  id           String   @id @default(uuid())

  salesOrderId String
  salesOrder   SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)

  description  String
  itemType     String?  @default("GOODS")
  hsnSacCode   String?
  quantity     Float
  price        Float
  taxPercent   Float?   @default(0)
  total        Float
}

model PurchaseOrder {
  id            String   @id @default(uuid())

  //////////////////////////////////////////////////////
  // BUSINESS
  //////////////////////////////////////////////////////
  businessId    String
  business      Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  //////////////////////////////////////////////////////
  // BASIC
  //////////////////////////////////////////////////////
  poNumber      String   @unique
  status        String   @default("Draft")

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////
  vendorId      String
  vendor        Vendor @relation(fields: [vendorId], references: [id])

  assignedToId  String?
  assignedTo    BusinessUser? @relation(fields: [assignedToId], references: [id])

  //////////////////////////////////////////////////////
  // PRICING
  //////////////////////////////////////////////////////
  subtotal      Float
  tax           Float?
  discount      Float?
  totalAmount   Float

  //////////////////////////////////////////////////////
  // DATES
  //////////////////////////////////////////////////////
  orderDate     DateTime
  expectedDeliveryDate DateTime?

  //////////////////////////////////////////////////////
  // NOTES
  //////////////////////////////////////////////////////
  notes         String?

  items         PurchaseOrderItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([businessId])
  bills Bill[]
}

model PurchaseOrderItem {
  id               String   @id @default(uuid())

  purchaseOrderId  String
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  description      String
  itemType         String?
  hsnSacCode       String?
  quantity         Int
  price            Float
  taxPercent       Float?   @default(0)
  total            Float
}

model Bill {
  id            String   @id @default(uuid())

  //////////////////////////////////////////////////////
  // BUSINESS
  //////////////////////////////////////////////////////
  businessId    String
  business      Business @relation(fields: [businessId], references: [id])

  //////////////////////////////////////////////////////
  // BASIC
  //////////////////////////////////////////////////////
  billNumber    String
  status        BillStatus @default(UNPAID)

  //////////////////////////////////////////////////////
  // RELATIONS
  //////////////////////////////////////////////////////
  vendorId      String
  vendor        Vendor @relation(fields: [vendorId], references: [id])

  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  //////////////////////////////////////////////////////
  // PRICING
  //////////////////////////////////////////////////////
  subtotal      Float
  tax           Float?
  discount      Float?
  totalAmount   Float

  //////////////////////////////////////////////////////
  // DATES
  //////////////////////////////////////////////////////
  billDate      DateTime
  dueDate       DateTime?

  //////////////////////////////////////////////////////
  // NOTES
  //////////////////////////////////////////////////////
  notes         String?

  items         BillItem[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([businessId, billNumber])
  @@index([businessId])
  payments Payment[]
}
model BillItem {
  id        String   @id @default(uuid())

  billId    String
  bill      Bill @relation(fields: [billId], references: [id], onDelete: Cascade)

  name      String
  quantity  Int
  price     Float
  total     Float
}

enum BillStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

model Product {
  id          String   @id @default(uuid())
  businessId  String

  name        String
  description String?
  sku         String   @unique

  price       Float
  costPrice   Float

    // 🔥 ADD THIS
  type        ItemType
  taxCode     String?   // HSN or SAC
  taxPercent  Float    @default(0)

  unit        String   @default("pcs")
  isActive    Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stock       Stock[]

  business    Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

enum ItemType {
  GOODS
  SERVICE
}


model Warehouse {
  id         String   @id @default(uuid())
  businessId String

  name       String
  address    String?
  city       String?
  country    String?

  isActive   Boolean  @default(true)

  createdAt  DateTime @default(now())

  stock      Stock[]

  business   Business @relation(fields: [businessId], references: [id])
}

model Stock {
  id          String   @id @default(uuid())

  productId   String
  warehouseId String

  quantity    Float    @default(0)
  reservedQty Float    @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
}

model Account {
  id         String   @id @default(uuid())
  businessId String

  name       String
  type       AccountType
  code       String?
  isActive   Boolean  @default(true)

  createdAt  DateTime @default(now())

  business   Business @relation(fields: [businessId], references: [id])
  entries    JournalEntry[]
}

model stock_transfer_items {
  id              String          @id
  stockTransferId String
  productId       String
  quantity        Float
  batchNumber     String?
  serialNumbers   String[]
  Product         Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  stock_transfers stock_transfers @relation(fields: [stockTransferId], references: [id], onDelete: Cascade)
}

model stock_transfers {
  id                                                   String                 @id
  businessId                                           String
  transferNumber                                       String
  fromWarehouseId                                      String
  toWarehouseId                                        String
  status                                               StockTransferStatus    @default(PENDING)
  transferDate                                         DateTime               @default(now())
  notes                                                String?
  createdAt                                            DateTime               @default(now())
  updatedAt                                            DateTime               @updatedAt
  stock_transfer_items                                 stock_transfer_items[]
  businesses                                           Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Warehouse_stock_transfers_fromWarehouseIdToWarehouse Warehouse              @relation("stock_transfers_fromWarehouseIdToWarehouse", fields: [fromWarehouseId], references: [id])
  Warehouse_stock_transfers_toWarehouseIdToWarehouse   Warehouse              @relation("stock_transfers_toWarehouseIdToWarehouse", fields: [toWarehouseId], references: [id])

  @@unique([businessId, transferNumber])
  @@index([businessId])
}

model units {
  id          String    @id
  businessId  String
  name        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  Product     Product[]
  businesses  Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, name])
  @@index([businessId])
}

