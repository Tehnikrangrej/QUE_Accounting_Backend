model Quotation {
  id              String           @id @default(uuid())
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  businessId      String
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  quoteNumber     String           @unique
  title           String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  customerId      String
  dealId          String?
  assignedToId    String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  subtotal        Float            @default(0)
  tax             Float            @default(0)
  discount        Float            @default(0)
  totalAmount     Float            @default(0)
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  issueDate       DateTime         @default(now())
  expiryDate      DateTime?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  contactId       String?
  currency        String           @default("INR")
  
  // India specific fields
  cgst            Float?
  sgst            Float?
  igst            Float?
  tds             Float?
  ewayBillNo      String?
  reverseCharge   Boolean          @default(false)
  transportDetails String?
  placeOfSupply   String?

  // UAE specific fields
  vatPercentage   Float?
  vatAmount       Float?
  vatType         String?          // "inclusive" or "exclusive"
  emirate         String?

  // General ERP fields
  customerReference String?
  shippingMethod    String?
  paymentTerms      String?
  deliveryInstructions String?
  shippingCharges   Float?           @default(0)

  deletedAt       DateTime?
  isDeleted       Boolean          @default(false)
  termsConditions String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  status          QuotationStatus  @default(DRAFT)
  assignedTo      BusinessUser?    @relation(fields: [assignedToId], references: [id])
  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  CustomerContact CustomerContact? @relation(fields: [contactId], references: [id])
  customer        Customer         @relation(fields: [customerId], references: [id])
  deal            Deal?            @relation(fields: [dealId], references: [id])
  items           QuotationItem[]
  salesOrders     SalesOrder[]
  invoices        Invoice[]

  @@index([businessId])
  @@index([customerId])
  @@index([dealId])
  @@index([isDeleted])
}

model QuotationItem {
  id          String    @id @default(uuid())
