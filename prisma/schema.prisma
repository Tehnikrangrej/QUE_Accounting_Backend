generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String         @id @default(uuid())
  name             String
  email            String         @unique
  password         String
  createdAt        DateTime       @default(now())
  isActive         Boolean        @default(true)
  role             UserRole       @default(USER)
  updatedAt        DateTime       @updatedAt
  activeBusinessId String?
  employees        Employee?
  memberships      BusinessUser[]
  businessesOwned  Business[]     @relation("BusinessOwner")
  activeBusiness   Business?      @relation("ActiveBusiness", fields: [activeBusinessId], references: [id])
  settings         Settings[]     @relation("SettingsToUser")

  @@map("users")
}

model Business {
  id                  String                @id @default(uuid())
  name                String
  ownerId             String
  isActive            Boolean               @default(true)
  createdAt           DateTime              @default(now())
  accounts            Account[]
  activities          Activity[]
  bills               Bill[]
  Campaign            Campaign[]
  contracts           Contract[]
  contractTypes       ContractType[]
  creditNotes         CreditNote[]
  CrmTask             CrmTask[]
  customerContacts    CustomerContact[]
  deals               Deal[]
  EmailLog            EmailLog[]
  employees           Employee[]
  expenses            Expense[]
  journalEntries      JournalEntry[]
  leads               Lead[]
  LeadConversionLog   LeadConversionLog[]
  Note                Note[]
  overtimes           Overtime[]
  products            Product[]
  projects            Project[]
  PurchaseOrder       PurchaseOrder[]
  quotations          Quotation[]
  salesOrders         SalesOrder[]
  settings            Settings?
  timeEntries         TimeEntry[]
  vendors             Vendor[]
  warehouses          Warehouse[]
  audit_logs          audit_logs[]
  batches             batches[]
  brands              brands[]
  users               BusinessUser[]
  owner               User                  @relation("BusinessOwner", fields: [ownerId], references: [id])
  categories          categories[]
  customers           Customer[]
  goods_receive_notes goods_receive_notes[]
  invoices            Invoice[]
  notifications       notifications[]
  payments            Payment[]
  purchase_requests   purchase_requests[]
  purchase_returns    purchase_returns[]
  recurring_invoices  recurring_invoices[]
  roles               Role[]
  sales_returns       sales_returns[]
  serial_numbers      serial_numbers[]
  stock_adjustments   stock_adjustments[]
  stockMovements      StockMovement[]
  stock_transfers     stock_transfers[]
  subscription        Subscription?
  units               units[]
  activeUsers         User[]                @relation("ActiveBusiness")

  @@map("businesses")
}

model BusinessUser {
  id                                           String              @id @default(uuid())
  userId                                       String
  businessId                                   String
  roleId                                       String
  isActive                                     Boolean             @default(true)
  createdAt                                    DateTime            @default(now())
  activities                                   Activity[]
  CrmTask_CrmTask_assignedToIdTobusiness_users CrmTask[]           @relation("CrmTask_assignedToIdTobusiness_users")
  CrmTask_CrmTask_createdByIdTobusiness_users  CrmTask[]           @relation("CrmTask_createdByIdTobusiness_users")
  CustomerContact                              CustomerContact[]
  deals                                        Deal[]
  leads                                        Lead[]
  LeadConversionLog                            LeadConversionLog[]
  Note                                         Note[]
  projectMembers                               ProjectMember[]
  PurchaseOrder                                PurchaseOrder[]
  quotations                                   Quotation[]
  salesOrders                                  SalesOrder[]
  taskAssignees                                TaskAssignee[]
  timeEntries                                  TimeEntry[]
  business                                     Business            @relation(fields: [businessId], references: [id])
  role                                         Role                @relation(fields: [roleId], references: [id])
  user                                         User                @relation(fields: [userId], references: [id])
  customers                                    Customer[]
  purchase_requests                            purchase_requests[]
  userPermissions                              UserPermission[]

  @@unique([userId, businessId])
  @@index([businessId])
  @@map("business_users")
}

model Role {
  id              String           @id @default(uuid())
  name            String
  businessId      String
  createdAt       DateTime         @default(now())
  users           BusinessUser[]
  rolePermissions RolePermission[]
  business        Business         @relation(fields: [businessId], references: [id])

  @@unique([businessId, name])
  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  action          String
  moduleId        String
  module          Module           @relation(fields: [moduleId], references: [id])
  rolePermissions RolePermission[]
  userPermissions UserPermission[]

  @@unique([moduleId, action])
  @@map("permissions")
}

model Module {
  id          String       @id @default(uuid())
  name        String       @unique
  permissions Permission[]

  @@map("modules")
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model UserPermission {
  id             String       @id @default(uuid())
  businessUserId String
  permissionId   String
  businessUser   BusinessUser @relation(fields: [businessUserId], references: [id])
  permission     Permission   @relation(fields: [permissionId], references: [id])

  @@unique([businessUserId, permissionId])
  @@map("user_permissions")
}

/// ///////////////////////////////////////////////////
/// ///////////////////////////////////////////////////
model Customer {
  id                 String               @id @default(uuid())
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  businessId         String
  phone              String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  address            String?
  createdAt          DateTime             @default(now())
  billingCity        String?
  billingCountry     String?
  billingState       String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  billingStreet      String?
  billingZipCode     String?
  city               String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  company            String
  country            String?
  currency           String               @default("SYSTEM")
  defaultLanguage    String               @default("SYSTEM")
  group              String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  isActive           Boolean              @default(true)
  shippingCity       String?
  shippingCountry    String?
  shippingState      String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  shippingStreet     String?
  shippingZipCode    String?
  state              String?
  updatedAt          DateTime             @updatedAt
  vatNumber          String?
  website            String?
  zipCode            String?
  leadId             String?              @unique
  region             Region
  emirate            String?
  tax_number         String?
  gst_number         String?
  trn_number         String?
  accountOwnerId     String?
  accountType        CrmAccountType?
  annualRevenue      Float?
  crmStatus          CrmStatus?
  deletedAt          DateTime?
  description        String?
  employeeCount      Int?
  facebookUrl        String?
  industry           String?
  isDeleted          Boolean              @default(false)
  lastContactedAt    DateTime?
  linkedinUrl        String?
  parentAccountId    String?
  tags               String[]
  twitterUrl         String?
  activities         Activity[]
  contracts          Contract[]
  creditNotes        CreditNote[]
  CrmTask            CrmTask[]
  customerContacts   CustomerContact[]
  deals              Deal[]
  EmailLog           EmailLog[]
  LeadConversionLog  LeadConversionLog[]
  Note               Note[]
  quotations         Quotation[]
  salesOrders        SalesOrder[]
  CustomerToLead     CustomerToLead[]
  CustomerToProject  CustomerToProject[]
  business_users     BusinessUser?        @relation(fields: [accountOwnerId], references: [id])
  business           Business             @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customers          Customer?            @relation("customersTocustomers", fields: [parentAccountId], references: [id])
  other_customers    Customer[]           @relation("customersTocustomers")
  invoices           Invoice[]
  recurring_invoices recurring_invoices[]
  sales_returns      sales_returns[]

  @@index([businessId])
  @@index([accountOwnerId])
  @@index([isDeleted])
  @@index([parentAccountId])
  @@map("customers")
}

model Invoice {
  id              String           @id @default(uuid())
  businessId      String
  customerId      String
  invoiceNumber   String
  status          InvoiceStatus    @default(UNPAID)
  dueDate         DateTime?
  createdAt       DateTime         @default(now())
  adminNote       String?
  currency        String           @default("AED")
  discount        Float            @default(0)
  grandTotal      Float            @default(0)
  invoiceDate     DateTime         @default(now())
  poDate          DateTime?
  poNumber        String?
  subtotal        Float            @default(0)
  terms           String?
  totalTax        Float            @default(0)
  shippingCharges Float            @default(0)
  updatedAt       DateTime         @updatedAt
  pdfUrl          String?
  salesOrderId    String?
  projectId       String?
  designTemplate  String           @default("modern")
  soDate          DateTime?
  soNumber        String?
  contactId       String?
  
  // India specific fields
  cgst            Float?
  sgst            Float?
  igst            Float?
  tds             Float?
  ewayBillNo      String?
  reverseCharge   Boolean          @default(false)
  transportDetails String?

  // UAE specific fields
  vatPercentage   Float?
  vatAmount       Float?
  vatType         String?          // "inclusive" or "exclusive"
  emirate         String?

  deletedAt       DateTime?
  isDeleted       Boolean          @default(false)
  quotationId     String?
  creditNotes     CreditNote[]
  items           InvoiceItem[]
  business        Business         @relation(fields: [businessId], references: [id])
  CustomerContact CustomerContact? @relation(fields: [contactId], references: [id])
  customer        Customer         @relation(fields: [customerId], references: [id])
  project         Project?         @relation(fields: [projectId], references: [id])
  Quotation       Quotation?       @relation(fields: [quotationId], references: [id])
  salesOrder      SalesOrder?      @relation(fields: [salesOrderId], references: [id])
  payments        Payment[]
  sales_returns   sales_returns[]

  @@unique([businessId, invoiceNumber])
  @@index([businessId])
  @@map("invoices")
}

model InvoiceItem {
  id          String     @id @default(uuid())
  invoiceId   String
  description String
  amount      Float
  createdAt   DateTime   @default(now())
  hours       Float
  rate        Float
  taxDetails  Json?
  totalAmount Float      @default(0)
  totalTax    Float      @default(0)
  taxPercent  Float      @default(0)
  hsnSacCode  String?
  itemType    String?
  unit        String?
  discount    Float      @default(0)
  productId   String?
  warehouseId String?
  quantity    Int        @default(1)
  invoice     Invoice    @relation(fields: [invoiceId], references: [id])
  product     Product?   @relation(fields: [productId], references: [id])
  warehouse   Warehouse? @relation(fields: [warehouseId], references: [id])

  @@map("invoice_items")
}

model Subscription {
  id         String             @id @default(uuid())
  businessId String             @unique
  status     SubscriptionStatus @default(INACTIVE)
  startDate  DateTime?
  expiresAt  DateTime?
  planName   String?
  notes      String?
  createdAt  DateTime           @default(now())
  business   Business           @relation(fields: [businessId], references: [id])

  @@map("subscriptions")
}

/// ///////////////////////////////////////////////////
/// ///////////////////////////////////////////////////
model Settings {
  id                Int      @id @default(autoincrement())
  businessId        String   @unique
  companyName       String
  address           String?
  phone             String?
  email             String?
  website           String?
  trn               String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  accountName       String?
  accountNumber     String?
  bankAddress       String?
  bankName          String?
  companyLogo       String?
  iban              String?
  swiftCode         String?
  defaultFooterNote String?
  defaultTerms      String?
  invoiceFormat     String   @default("INV-YYYY-MM-DD-COUNT")
  signatureUrl      String?
  leaveTypes        Json?
  overtimeThreshold Float    @default(2)
  currency          String   @default("INR")
  currencySymbol    String   @default("₹")
  invoiceTemplate   String   @default("modern")
  busniess          Business @relation(fields: [businessId], references: [id])
  users             User[]   @relation("SettingsToUser")
}

model Payment {
  id            String      @id @default(uuid())
  invoiceId     String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  businessId    String
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  amount        Float
  paymentDate   DateTime
  paymentMode   String
  transactionId String?
  note          String?
  createdAt     DateTime    @default(now())
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  createdBy     String
  pdfUrl        String?
  creditNoteId  String?
  paymentNumber String
  billId        String?
  bill          Bill?       @relation(fields: [billId], references: [id])
  business      Business    @relation(fields: [businessId], references: [id])
  creditNote    CreditNote? @relation(fields: [creditNoteId], references: [id])
  invoice       Invoice?    @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
  @@map("payments")
}

model CreditNote {
  id              String           @id @default(uuid())
  /// /////////////////////////////////////////////////
  /// /////////////////////////////////////////////////
  businessId      String
  customerId      String?
  invoiceId       String?
  /// /////////////////////////////////////////////////
  /// /////////////////////////////////////////////////
  creditNumber    String
  amount          Float
  remainingAmount Float
  reason          String?
  status          CreditNoteStatus @default(OPEN)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  pdfUrl          String?
  type            CreditNoteType
  vendorId        String?
  deletedAt       DateTime?
  isDeleted       Boolean          @default(false)
  salesReturnId   String?
  business        Business         @relation(fields: [businessId], references: [id])
  customer        Customer?        @relation(fields: [customerId], references: [id])
  invoice         Invoice?         @relation(fields: [invoiceId], references: [id])
  sales_returns   sales_returns?   @relation(fields: [salesReturnId], references: [id])
  vendor          Vendor?          @relation(fields: [vendorId], references: [id])
  payments        Payment[]

  @@index([businessId])
  @@index([customerId])
}

model Employee {
  id                 String              @id @default(uuid())
  businessId         String
  name               String
  email              String?
  phone              String?
  designation        String?
  joinDate           DateTime?
  basicSalary        Float
  createdAt          DateTime            @default(now())
  allowance          Json?
  deduction          Json?
  leaveBalance       Json?
  userId             String?             @unique
  accountHolderName  String?
  accountNumber      String?
  bankName           String?
  Code               String?
  bankChangeRequests BankChangeRequest[]
  business           Business            @relation(fields: [businessId], references: [id])
  user               User?               @relation(fields: [userId], references: [id])
  leaves             Leave[]
  loans              Loan[]
  overtimes          Overtime[]
  payslips           Payslip[]
  projectMembers     ProjectMember[]
  taskAssignees      TaskAssignee[]
  timeEntries        TimeEntry[]
}

model Payslip {
  id            String   @id @default(uuid())
  payrollId     String
  employeeId    String
  basicSalary   Float
  allowance     Float    @default(0)
  deduction     Float    @default(0)
  netSalary     Float
  status        String   @default("pending")
  pdfUrl        String?
  createdAt     DateTime @default(now())
  employeeName  String
  overtimePay   Float    @default(0)
  loanDeduction Float    @default(0)
  employee      Employee @relation(fields: [employeeId], references: [id])
  payroll       Payroll  @relation(fields: [payrollId], references: [id])
}

model Payroll {
  id         String    @id @default(uuid())
  businessId String
  month      Int
  year       Int
  status     String    @default("draft")
  createdAt  DateTime  @default(now())
  payslips   Payslip[]
}

model Leave {
  id         String   @id @default(uuid())
  businessId String
  employeeId String
  leaveCode  String
  date       DateTime
  duration   String
  createdAt  DateTime @default(now())
  status     String   @default("PENDING")
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model BankChangeRequest {
  id                String        @id @default(uuid())
  employeeId        String
  businessId        String
  bankName          String
  accountNumber     String
  accountHolderName String
  status            RequestStatus @default(PENDING)
  createdAt         DateTime      @default(now())
  Code              String
  country           String
  employee          Employee      @relation(fields: [employeeId], references: [id])
}

model Overtime {
  id            String   @id @default(uuid())
  employeeId    String
  businessId    String
  overtimeHours Float
  date          DateTime
  createdAt     DateTime @default(now())
  business      Business @relation(fields: [businessId], references: [id])
  employee      Employee @relation(fields: [employeeId], references: [id])

  @@index([businessId, employeeId])
}

model Loan {
  id              String   @id @default(uuid())
  employeeId      String
  businessId      String
  totalAmount     Float
  remainingAmount Float
  emiAmount       Float
  startDate       DateTime
  status          String   @default("active")
  createdAt       DateTime @default(now())
  employee        Employee @relation(fields: [employeeId], references: [id])
}

model Expense {
  id            String   @id @default(uuid())
  businessId    String
  title         String
  amount        Float
  category      String
  paymentMethod String
  date          DateTime
  notes         String?
  vendorId      String?
  createdAt     DateTime @default(now())
  business      Business @relation(fields: [businessId], references: [id])
  vendor        Vendor?  @relation(fields: [vendorId], references: [id])
}

model Vendor {
  id                  String                @id @default(uuid())
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  businessId          String
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  name                String
  email               String?
  phone               String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  createdAt           DateTime              @default(now())
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  address             String?
  city                String?
  country             String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  isActive            Boolean               @default(true)
  state               String?
  updatedAt           DateTime              @updatedAt
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  vatNumber           String?
  website             String?
  zipCode             String?
  balance             Float                 @default(0)
  companyName         String?
  paymentTerms        String?
  status              String                @default("ACTIVE")
  taxNumber           String?
  bills               Bill[]
  creditNotes         CreditNote[]
  expenses            Expense[]
  PurchaseOrder       PurchaseOrder[]
  business            Business              @relation(fields: [businessId], references: [id])
  goods_receive_notes goods_receive_notes[]
  purchase_returns    purchase_returns[]
}

model CustomerContact {
  id             String        @id @default(uuid())
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  customerId     String
  businessId     String
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  fullName       String
  email          String?
  position       String?
  phone          String?
  isActive       Boolean       @default(true)
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  contactOwnerId String?
  deletedAt      DateTime?
  isDeleted      Boolean       @default(false)
  isPrimary      Boolean       @default(false)
  tags           String[]
  Activity       Activity[]
  CrmTask        CrmTask[]
  business       Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  business_users BusinessUser? @relation(fields: [contactOwnerId], references: [id])
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deals          Deal[]
  EmailLog       EmailLog[]
  Note           Note[]
  Quotation      Quotation[]
  SalesOrder     SalesOrder[]
  invoices       Invoice[]

  @@index([customerId])
  @@index([businessId])
  @@index([contactOwnerId])
  @@index([isDeleted])
}

model Contract {
  id          String         @id @default(uuid())
  businessId  String
  customerId  String
  title       String
  description String?
  value       Float
  currency    String
  startDate   DateTime
  endDate     DateTime?
  isDeleted   Boolean        @default(false)
  isHidden    Boolean        @default(false)
  status      ContractStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime  @updatedAt       
  typeId      String?
  business    Business       @relation(fields: [businessId], references: [id])
  customer    Customer       @relation(fields: [customerId], references: [id])
  type        ContractType?  @relation(fields: [typeId], references: [id])

  @@index([businessId])
  @@index([customerId])
}

model ContractType {
  id         String     @id @default(uuid())
  name       String
  businessId String
  createdAt  DateTime   @default(now())
  contracts  Contract[]
  business   Business   @relation(fields: [businessId], references: [id])

  @@unique([businessId, name])
}

model Lead {
  id                String             @id @default(uuid())
  businessId        String
  name              String
  position          String?
  email             String?
  phone             String?
  company           String?
  website           String?
  city              String?
  state             String?
  country           String?
  zipCode           String?
  status            LeadStatus         @default(NEW)
  source            LeadSource
  assignedToId      String?
  tags              String[]
  leadValue         Float?
  description       String?
  isPublic          Boolean            @default(false)
  contactedToday    Boolean            @default(false)
  defaultLanguage   String?
  stageId           String?
  score             Int                @default(0)
  isDeleted         Boolean            @default(false)
  deletedAt         DateTime?
  campaignId        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  activity          Activity[]
  CrmTask           CrmTask[]
  EmailLog          EmailLog[]
  assignedTo        BusinessUser?      @relation(fields: [assignedToId], references: [id])
  business          Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Campaign          Campaign?          @relation(fields: [campaignId], references: [id])
  stage             PipelineStage?     @relation(fields: [stageId], references: [id])
  activities        LeadActivity[]
  LeadConversionLog LeadConversionLog?
  notes             LeadNote[]
  reminders         LeadReminder[]
  tasks             LeadTask[]
  Note              Note[]
  CustomerToLead    CustomerToLead[]

  @@index([assignedToId])
  @@index([businessId])
  @@index([campaignId])
  @@index([isDeleted])
  @@index([stageId])
}

model PipelineStage {
  id    String  @id @default(uuid())
  name  String
  order Int
  color String?
  leads Lead[]
}

model LeadActivity {
  id        String   @id @default(uuid())
  leadId    String
  message   String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id])
}

model LeadNote {
  id        String   @id @default(uuid())
  leadId    String
  note      String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id])
}

model LeadTask {
  id        String   @id @default(uuid())
  leadId    String
  title     String
  status    String
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id])
}

model LeadReminder {
  id     String   @id @default(uuid())
  leadId String
  title  String
  date   DateTime
  lead   Lead     @relation(fields: [leadId], references: [id])
}

model Deal {
  id                String             @id @default(uuid())
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  businessId        String
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  name              String
  amount            Float
  currency          String             @default("INR")
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  customerId        String
  contactId         String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  stage             String             @default("New")
  probability       Int?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  expectedCloseDate DateTime?
  status            DealStatus         @default(OPEN)
  lostReason        String?
  campaignId        String?
  isDeleted         Boolean            @default(false)
  deletedAt         DateTime?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  assignedToId      String?
  source            String?
  description       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  activities        Activity[]
  CrmTask           CrmTask[]
  assignedTo        BusinessUser?      @relation(fields: [assignedToId], references: [id])
  business          Business           @relation(fields: [businessId], references: [id], onDelete: Cascade)
  Campaign          Campaign?          @relation(fields: [campaignId], references: [id])
  contact           CustomerContact?   @relation(fields: [contactId], references: [id])
  customer          Customer           @relation(fields: [customerId], references: [id], onDelete: Cascade)
  DealStageHistory  DealStageHistory[]
  EmailLog          EmailLog[]
  Note              Note[]
  quotations        Quotation[]
  salesOrders       SalesOrder[]

  @@index([businessId])
  @@index([customerId])
  @@index([assignedToId])
  @@index([campaignId])
  @@index([contactId])
  @@index([isDeleted])
}

model Activity {
  id              String           @id @default(uuid())
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  businessId      String
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
  type            String
  title           String
  description     String?
  /// ///////////////////////////////////////////////////
  /// ///////////////////////////////////////////////////
